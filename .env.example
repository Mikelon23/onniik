# ==========================================
# ONNIIK - CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ==========================================
# Duplicar este archivo como '.env' para desarrollo local.
# NUNCA subir credenciales reales ni el archivo '.env' a Git.

# 1. BASE DE DATOS (Prisma y Redis)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/onniik?schema=public"
REDIS_URL="redis://localhost:6379"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# 2. AUTENTICACIÓN (NextAuth / Google SSO)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="ejemplo_hash_secreto_muy_largo_de_32_caracteres"

# Credenciales de Google Cloud Console (OAuth Client ID)
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-tu-google-client-secret"

# 3. AUDITORÍA DE INTEGRACIONES (Workspace & Slack)
GOOGLE_WORKSPACE_CUSTOMER_ID="my_customer"

# Slack App credentials
SLACK_CLIENT_ID="123456789.123456789"
SLACK_CLIENT_SECRET="slack-client-secret-here"
SLACK_SIGNING_SECRET="slack-signing-secret-here"

# 4. PASARELA DE FACTURACIÓN INTERNA (Stripe)
STRIPE_PUBLISHABLE_KEY="pk_test_tu-stripe-public-key"
STRIPE_SECRET_KEY="sk_test_tu-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_tu-stripe-webhook-secret"
