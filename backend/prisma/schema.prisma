datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  READER
  IT_MANAGER
}

/// Categoría funcional del producto SaaS detectado
enum SaaSCategory {
  PRODUCTIVITY      // Notion, Confluence, Google Workspace
  COMMUNICATION     // Slack, Zoom, Teams, Loom
  DEVELOPMENT       // GitHub, GitLab, Linear, Jira
  SALES_CRM         // Salesforce, HubSpot, Pipedrive
  MARKETING         // Mailchimp, ActiveCampaign, Clearbit
  DESIGN            // Figma, Canva, Adobe CC
  FINANCE           // Expensify, Ramp, Brex, QuickBooks
  HR_PEOPLE         // Lattice, Rippling, BambooHR
  SECURITY          // 1Password, Okta, Snyk, Cloudflare
  INFRASTRUCTURE    // AWS, GCP, Azure, Vercel, Netlify
  ANALYTICS         // Mixpanel, Amplitude, PostHog, Datadog
  CUSTOMER_SUCCESS  // Intercom, Zendesk, Crisp
  OTHER             // Sin categoría determinada
}

/// Ciclo de facturación de la suscripción
enum BillingCycle {
  MONTHLY
  QUARTERLY
  ANNUAL
  ONE_TIME
  CUSTOM
}

/// Estado operacional de la suscripción dentro de la organización
enum SubscriptionStatus {
  ACTIVE          // Suscripción vigente y en uso
  INACTIVE        // Detectada pero sin uso confirmado
  CANCELLED       // Cancelada por el usuario o el agente de IA
  PENDING_REVIEW  // Marcada para revisión por el equipo de IT
  SHADOW_IT       // Detectada sin aprobación formal del equipo de IT
}

/// Fuente de detección de la suscripción
enum DetectionSource {
  GOOGLE_WORKSPACE  // Detectada vía API de Google Workspace
  SLACK             // Detectada vía API de Slack Apps
  EMAIL_SCAN        // Detectada vía escaneo de facturas en Gmail
  CSV_IMPORT        // Importada manualmente vía CSV
  MANUAL_ENTRY      // Ingresada manualmente por un administrador
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model Organization {
  id               String             @id @default(uuid())
  name             String
  googleCustomerId String?            @map("google_customer_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  // Relaciones
  users            User[]
  subscriptions    SaaSSubscription[]
  oauthCredentials OAuthCredential[]
  activityLogs     ActivityLog[]
  alerts           OptimizationAlert[]

  @@map("organizations")
}

/// Usuario de la plataforma Onniik.
///
/// Relaciones con el motor de recomendaciones IA (Tarea 73):
///   - ownedSubscriptions : suscripciones de las que este usuario es responsable
///   - triggeredAlerts    : alertas cuya detección fue iniciada manualmente por este usuario
///                          (a diferencia de las generadas automáticamente por el sistema IA,
///                          donde triggeredByUserId es NULL)
///   - resolvedAlerts     : alertas que este usuario aceptó o descartó
///   - activityLogs       : historial de acciones auditables
model User {
  id             String             @id @default(uuid())
  email          String             @unique
  passwordHash   String             @map("password_hash")
  name           String?
  role           Role               @default(READER)
  organizationId String             @map("organization_id")
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  // Relaciones
  ownedSubscriptions SaaSSubscription[]  @relation("SubscriptionOwner")
  activityLogs       ActivityLog[]        @relation("UserActivityLogs")
  triggeredAlerts    OptimizationAlert[]  @relation("AlertTrigger")    // Alertas iniciadas manualmente por el usuario
  resolvedAlerts     OptimizationAlert[]  @relation("AlertResolver")   // Alertas resueltas (aceptadas/descartadas)

  @@index([organizationId])
  @@map("users")
}

/// Catálogo global de productos SaaS conocidos por Onniik.
/// Representa la herramienta en sí (ej. "Slack", "GitHub"), no la suscripción.
/// Es compartido entre todas las organizaciones.
model SaaSProduct {
  id          String       @id @default(uuid())
  name        String       @unique
  slug        String       @unique
  category    SaaSCategory @default(OTHER)
  description String?
  website     String?
  logoUrl     String?      @map("logo_url")
  vendor      String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relaciones
  subscriptions SaaSSubscription[]

  @@index([category])
  @@index([slug])
  @@map("saas_products")
}

/// Suscripción activa (o histórica) de una organización a un producto SaaS.
/// Es el núcleo del inventario de Onniik — cada fila representa un contrato
/// o licencia que la organización tiene con un proveedor SaaS.
model SaaSSubscription {
  id               String             @id @default(uuid())
  organizationId   String             @map("organization_id")
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  saasProductId    String             @map("saas_product_id")
  saasProduct      SaaSProduct        @relation(fields: [saasProductId], references: [id], onDelete: Restrict)

  // Responsable interno de la suscripción (puede ser null si es Shadow IT)
  ownerId          String?            @map("owner_id")
  owner            User?              @relation("SubscriptionOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // Estado y clasificación
  status           SubscriptionStatus @default(ACTIVE)
  detectionSource  DetectionSource    @default(MANUAL_ENTRY) @map("detection_source")

  // Información financiera
  seatCount        Int?               @map("seat_count")
  activeSeats      Int?               @map("active_seats")
  costPerSeat      Decimal?           @map("cost_per_seat") @db.Decimal(10, 2)
  totalMonthlyCost Decimal?           @map("total_monthly_cost") @db.Decimal(12, 2)
  currency         String             @default("USD")
  billingCycle     BillingCycle       @default(MONTHLY) @map("billing_cycle")

  // Fechas del contrato
  renewalDate      DateTime?          @map("renewal_date")
  contractStart    DateTime?          @map("contract_start")
  contractEnd      DateTime?          @map("contract_end")

  // Metadatos de integración
  externalId       String?            @map("external_id")
  notes            String?

  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  // Alertas de optimización vinculadas a esta suscripción
  alerts           OptimizationAlert[]

  // Índices para queries de alto rendimiento en el Dashboard
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, saasProductId])
  @@index([renewalDate])
  @@index([status])
  @@index([detectionSource])

  // Restricción de unicidad: evitar duplicados de misma org + producto + externalId
  @@unique([organizationId, saasProductId, externalId], name: "unique_org_product_external")

  @@map("saas_subscriptions")
}

// ─────────────────────────────────────────────
// ENUMS — OAuth, Logs & Alerts
// ─────────────────────────────────────────────

/// Proveedor del token OAuth almacenado
enum OAuthProvider {
  GOOGLE_WORKSPACE  // Google Workspace / Google Directory API
  SLACK             // Slack Apps API
  STRIPE            // Stripe Billing API (futuro)
}

/// Categoría semántica de la acción registrada en el log
enum ActivityAction {
  // Autenticación
  USER_LOGIN
  USER_LOGOUT
  USER_REGISTER
  PASSWORD_CHANGED
  // Integraciones
  INTEGRATION_CONNECTED
  INTEGRATION_DISCONNECTED
  INTEGRATION_SYNC_STARTED
  INTEGRATION_SYNC_COMPLETED
  INTEGRATION_SYNC_FAILED
  // Inventario SaaS
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELLED
  SHADOW_IT_DETECTED
  // Alertas y IA
  ALERT_CREATED
  ALERT_ACCEPTED
  ALERT_DISMISSED
  AI_DRAFT_GENERATED
  // Administración
  MEMBER_INVITED
  MEMBER_REMOVED
  ROLE_CHANGED
  // Datos
  CSV_IMPORTED
  DATA_EXPORTED
}

/// Estado de ciclo de vida de una alerta de optimización
enum AlertStatus {
  PENDING    // Generada por IA, sin revisar
  ACCEPTED   // Aceptada por el administrador (acción iniciada)
  DISMISSED  // Ignorada por el administrador
  COMPLETED  // Acción completada y ahorro confirmado
  EXPIRED    // La ventana de oportunidad venció sin acción
}

/// Tipo de optimización recomendada por el motor de IA
enum AlertType {
  INACTIVE_SEATS         // Licencias asignadas a usuarios inactivos
  DUPLICATE_TOOL         // Herramienta duplicada con otra en el stack
  RENEWAL_APPROACHING    // Renovación próxima — oportunidad de negociar
  SHADOW_IT_FOUND        // Software detectado sin aprobación de IT
  COST_ANOMALY           // Gasto anormal detectado respecto al histórico
  LICENCE_DOWNGRADE      // Recomendación de bajar plan de licencia
  CANCELLATION_CANDIDATE // Herramienta sin uso — candidata a cancelación
}

/// Prioridad de la alerta de optimización generada por el motor de IA.
/// Permite al dashboard ordenar y destacar las oportunidades de mayor impacto.
/// Calculada por el LLM en función del ahorro estimado, urgencia y tipo.
enum AlertPriority {
  LOW      // Ahorro < $100/mes o impacto menor
  MEDIUM   // Ahorro entre $100–$500/mes o riesgo moderado
  HIGH     // Ahorro > $500/mes o riesgo de seguridad (Shadow IT)
  CRITICAL // Ahorro > $2000/mes, contrato por vencer o brecha de IT urgente
}

// ─────────────────────────────────────────────
// MODELS — OAuth, Logs & Alerts
// ─────────────────────────────────────────────

/// Credencial OAuth almacenada por integración y organización.
/// Los tokens se guardan cifrados (AES-256) a nivel de aplicación
/// antes de persistirse — este modelo guarda el ciphertext, no el plaintext.
model OAuthCredential {
  id               String        @id @default(uuid())
  organizationId   String        @map("organization_id")
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  provider         OAuthProvider

  // Tokens cifrados con AES-256 a nivel de aplicación (Task 197)
  accessTokenEnc   String        @map("access_token_enc")   // Ciphertext del access token
  refreshTokenEnc  String?       @map("refresh_token_enc")  // Ciphertext del refresh token (nullable en algunos providers)

  // Metadatos del token (no sensibles)
  scope            String?                                   // Scopes concedidos (ej. "read:users email")
  tokenType        String        @default("Bearer")         @map("token_type")
  expiresAt        DateTime?     @map("expires_at")          // Expiración del access token
  isActive         Boolean       @default(true)             @map("is_active")

  // Datos de la cuenta/workspace conectada (identificadores externos)
  externalAccountId String?      @map("external_account_id") // ID de cuenta del provider (ej. Google Workspace Customer ID)

  createdAt        DateTime      @default(now())             @map("created_at")
  updatedAt        DateTime      @updatedAt                  @map("updated_at")

  // Una organización solo puede tener una credencial activa por provider
  @@unique([organizationId, provider], name: "unique_org_provider")
  @@index([organizationId])
  @@index([provider])
  @@index([expiresAt])
  @@map("oauth_credentials")
}

/// Log inmutable de auditoría del sistema.
/// Registra cada acción crítica realizada por usuarios o por el sistema automatizado.
/// Los registros NUNCA se actualizan ni se borran (append-only).
model ActivityLog {
  id             String         @id @default(uuid())
  organizationId String         @map("organization_id")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Actor: puede ser un usuario humano o el sistema (agente IA, cron job)
  userId         String?        @map("user_id")
  user           User?          @relation("UserActivityLogs", fields: [userId], references: [id], onDelete: SetNull)
  actorType      String         @default("user") @map("actor_type") // "user" | "system" | "ai_agent"

  // Acción registrada
  action         ActivityAction
  entityType     String?        @map("entity_type")  // "subscription" | "user" | "integration" | etc.
  entityId       String?        @map("entity_id")    // UUID de la entidad afectada

  // Contexto adicional en JSON libre (metadatos variables por tipo de acción)
  metadata       Json?

  // Contexto de red (para auditoría de seguridad)
  ipAddress      String?        @map("ip_address")
  userAgent      String?        @map("user_agent")

  // Los logs no tienen updatedAt — son inmutables por diseño
  createdAt      DateTime       @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([organizationId, action])
  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

/// Alerta de optimización generada por el motor de IA de Onniik.
///
/// ──────────────────────────────────────────────────────────────
/// FLUJO COMPLETO DE RECOMENDACIÓN DE AHORRO IA (Tarea 73)
/// ──────────────────────────────────────────────────────────────
///
/// El motor de IA de Onniik genera alertas a través del siguiente pipeline:
///
///   1. DETECCIÓN (automática o manual)
///      ┌─────────────────────────────────────────────────────────┐
///      │ Sistema IA / Cron job / Usuario (triggeredByUserId)      │
///      │   ↓ analiza                                              │
///      │ SaaSSubscription (status, seatCount, activeSeats, cost)  │
///      │   + User (rol, última actividad via integración)          │
///      └─────────────────────────────────────────────────────────┘
///
///   2. CREACIÓN DE ALERTA
///      La IA genera un OptimizationAlert con:
///        - alertType    : clasifica la oportunidad (INACTIVE_SEATS, etc.)
///        - priority     : LOW / MEDIUM / HIGH / CRITICAL
///        - estimatedSavings : ahorro proyectado en USD/mes
///        - confidenceScore  : [0.0 – 1.0] confianza del modelo
///        - aiModelVersion   : versión del LLM usado
///        - triggeredByUserId: NULL si fue el sistema; UUID si fue manual
///
///   3. REVISIÓN HUMANA (Human-in-the-loop)
///      El administrador (resolvedBy) revisa la alerta y la:
///        - ACEPTA  → resolvedAt + resolutionNote + status = ACCEPTED
///        - DESCARTA → status = DISMISSED + resolutionNote
///        - IGNORA hasta expiresAt → status = EXPIRED (cron job)
///
///   4. CONFIRMACIÓN DE AHORRO
///      Tras ejecutar la acción (cancelar, negociar, downgrade):
///        - status = COMPLETED
///        - El ahorro real se registra en ActivityLog
/// ──────────────────────────────────────────────────────────────
///
/// QUERIES CRÍTICAS SOPORTADAS POR LOS ÍNDICES:
///   a) Dashboard KPI: "Total ahorro potencial PENDING por org"
///      → WHERE organizationId = ? AND status = 'PENDING'
///        ORDER BY estimated_savings DESC
///      → Índice: [organizationId, status, estimatedSavings]
///
///   b) Panel de alertas: "Alertas por tipo en una org"
///      → WHERE organizationId = ? AND alertType = ?
///      → Índice: [organizationId, alertType]
///
///   c) Expiración automática: "Alertas PENDING sin acción"
///      → WHERE status = 'PENDING' AND expiresAt <= NOW()
///      → Índice: [status, expiresAt]
///
model OptimizationAlert {
  id               String            @id @default(uuid())
  organizationId   String            @map("organization_id")
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Suscripción SaaS asociada a la alerta (puede ser null para alertas globales de org)
  subscriptionId   String?           @map("subscription_id")
  subscription     SaaSSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  // Actor que originó la alerta:
  // NULL  → generada automáticamente por el motor de IA / cron job
  // UUID  → iniciada manualmente por un usuario administrador o IT Manager
  triggeredByUserId String?          @map("triggered_by_user_id")
  triggeredBy       User?            @relation("AlertTrigger", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  // Tipo, prioridad y estado
  alertType        AlertType         @map("alert_type")
  priority         AlertPriority     @default(MEDIUM)
  status           AlertStatus       @default(PENDING)

  // Contenido de la alerta
  title            String            // Título corto (ej. "Slack: 12 asientos inactivos")
  description      String            // Descripción detallada del problema detectado
  recommendation   String            // Acción recomendada por el agente de IA

  // Impacto financiero estimado por la IA
  estimatedSavings Decimal?          @map("estimated_savings") @db.Decimal(12, 2)
  currency         String            @default("USD")

  // Contexto de IA (trazabilidad del modelo usado)
  aiModelVersion   String?           @map("ai_model_version")  // ej. "gpt-4o-mini", "claude-3-haiku"
  confidenceScore  Float?            @map("confidence_score")  // Score de confianza [0.0 – 1.0]
  aiRawResponse    Json?             @map("ai_raw_response")   // Respuesta cruda del LLM (para auditoría)

  // Resolución humana (Human-in-the-loop)
  resolvedById     String?           @map("resolved_by_id")
  resolvedBy       User?             @relation("AlertResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt       DateTime?         @map("resolved_at")
  resolutionNote   String?           @map("resolution_note")  // Nota del admin al aceptar/descartar

  // Expiración: si no se actúa antes de esta fecha → cron job la marca EXPIRED
  expiresAt        DateTime?         @map("expires_at")

  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  // ── Índices para queries de Dashboard e IA ──────────────────
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, alertType])
  @@index([organizationId, status, estimatedSavings], name: "optimization_alerts_dashboard_idx") // Query KPI dashboard
  @@index([status, expiresAt], name: "optimization_alerts_expiry_idx")                          // Cron de expiración
  @@index([subscriptionId])
  @@index([triggeredByUserId])
  @@index([status])
  @@index([priority])
  @@index([expiresAt])
  @@map("optimization_alerts")
}
